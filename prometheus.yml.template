global:
  scrape_interval: 15s

scrape_configs:
  - job_name: 'spring_microservices'
    metrics_path: '/actuator/prometheus'
    static_configs:
      - targets:
        - '${PRIVATE_IP_PAYMENT}:8081'
        - '${PRIVATE_IP_AUTH}:8082'
        - '${PRIVATE_IP_INVENTORY}:8083'

  - job_name: 'rust_order_service'
    metrics_path: '/metrics'
    static_configs:
      - targets:
        - '${PRIVATE_IP_ORDER}:8084'
