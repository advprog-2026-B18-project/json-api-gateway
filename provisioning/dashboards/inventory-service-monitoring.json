{
  "title": "Inventory Service Monitoring",
  "uid": "inventory-service-monitoring",
  "version": 1,
  "tags": ["inventory-service", "spring-boot", "product"],
  "timezone": "browser",
  "schemaVersion": 39,
  "editable": true,
  "refresh": "10s",
  "panels": [
    {
      "title": "CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus_main" },
      "targets": [
        {
          "expr": "system_cpu_usage{service=\"json-inventory-service\"}",
          "legendFormat": "CPU"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "palette-classic" },
          "custom": { "showPoints": "never" }
        }
      },
      "options": {
        "legend": {
          "calcs": ["mean", "max", "min"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "title": "Uptime",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus_main" },
      "targets": [
        {
          "expr": "process_uptime_seconds{service=\"json-inventory-service\"}",
          "legendFormat": "Uptime"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null }
            ]
          }
        }
      }
    },
    {
      "title": "CPU Usage",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus_main" },
      "targets": [
        {
          "expr": "system_cpu_usage{service=\"json-inventory-service\"}",
          "legendFormat": "CPU"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      }
    },
    {
      "title": "Heap Used",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus_main" },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{service=\"json-inventory-service\", area=\"heap\"} / jvm_memory_max_bytes{service=\"json-inventory-service\", area=\"heap\"} * 100",
          "legendFormat": "Heap"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "title": "Live Threads",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus_main" },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{service=\"json-inventory-service\"}",
          "legendFormat": "Threads"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      }
    },

    {
      "title": "Public Product Search Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus_main" },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{service=\"json-inventory-service\", uri=\"/products\", method=\"GET\"}[1m])",
          "legendFormat": "search"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "showPoints": "never" }
        }
      }
    },
    {
      "title": "Product Detail Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus_main" },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{service=\"json-inventory-service\", uri=~\"/products/.*\", method=\"GET\"}[1m])",
          "legendFormat": "detail"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "showPoints": "never" }
        }
      }
    },
    {
      "title": "Public Endpoint Error Rate (4xx+5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus_main" },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{service=\"json-inventory-service\", uri!~\"/internal/.*|/admin/.*\", status=~\"[45]..\"}[1m])",
          "legendFormat": "{{method}} {{uri}} {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "showPoints": "never" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.5 },
              { "color": "red", "value": 2 }
            ]
          }
        }
      }
    },
    {
      "title": "P95 Latency — Public Endpoints",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus_main" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_server_requests_seconds_bucket{service=\"json-inventory-service\", uri!~\"/internal/.*|/admin/.*\"}[5m]))",
          "legendFormat": "{{uri}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": { "showPoints": "never" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        }
      }
    },

    {
      "title": "Reserve Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus_main" },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{service=\"json-inventory-service\", uri=~\"/internal/products/.*/stock/reserve\"}[1m])",
          "legendFormat": "reserve"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "showPoints": "never" }
        }
      }
    },
    {
      "title": "Reserve Error Rate (400)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus_main" },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{service=\"json-inventory-service\", uri=~\"/internal/products/.*/stock/reserve\", status=\"400\"}[1m])",
          "legendFormat": "400/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "showPoints": "never" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0 },
              { "color": "red", "value": 0.1 }
            ]
          }
        }
      }
    },
    {
      "title": "Release Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus_main" },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{service=\"json-inventory-service\", uri=~\"/internal/products/.*/stock/release\"}[1m])",
          "legendFormat": "release"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "showPoints": "never" }
        }
      }
    },
    {
      "title": "Post-Order Error Rate (4xx+5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "prometheus_main" },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{service=\"json-inventory-service\", uri=~\"/internal/products/.*/post-order\", status=~\"[45]..\"}[1m])",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "showPoints": "never" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0 },
              { "color": "red", "value": 0.1 }
            ]
          }
        }
      }
    },
    {
      "title": "P99 Latency — Internal Endpoints",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "prometheus_main" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(http_server_requests_seconds_bucket{service=\"json-inventory-service\", uri=~\"/internal/.*\"}[5m]))",
          "legendFormat": "{{uri}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": { "showPoints": "never" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 2 }
            ]
          }
        }
      }
    },

    {
      "title": "Product Create Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 38 },
      "datasource": { "type": "prometheus", "uid": "prometheus_main" },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{service=\"json-inventory-service\", uri=\"/products\", method=\"POST\"}[1m])",
          "legendFormat": "create"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "showPoints": "never" }
        }
      }
    },
    {
      "title": "Product Update/Delete Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 38 },
      "datasource": { "type": "prometheus", "uid": "prometheus_main" },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{service=\"json-inventory-service\", uri=~\"/products/.*\", method=~\"PATCH|DELETE\", status=~\"[45]..\"}[1m])",
          "legendFormat": "{{method}} {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "showPoints": "never" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.5 },
              { "color": "red", "value": 2 }
            ]
          }
        }
      }
    },
    {
      "title": "Admin Moderation Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 38 },
      "datasource": { "type": "prometheus", "uid": "prometheus_main" },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{service=\"json-inventory-service\", uri=~\"/admin/products/.*/moderate\"}[1m])",
          "legendFormat": "moderate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "showPoints": "never" }
        }
      }
    },

    {
      "title": "Heap Memory by Region",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 46 },
      "datasource": { "type": "prometheus", "uid": "prometheus_main" },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{service=\"json-inventory-service\", area=\"heap\"}",
          "legendFormat": "{{id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" },
          "custom": { "showPoints": "never" }
        }
      }
    },
    {
      "title": "Non-Heap Memory by Region",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 46 },
      "datasource": { "type": "prometheus", "uid": "prometheus_main" },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{service=\"json-inventory-service\", area=\"nonheap\"}",
          "legendFormat": "{{id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" },
          "custom": { "showPoints": "never" }
        }
      }
    }
  ]
}
