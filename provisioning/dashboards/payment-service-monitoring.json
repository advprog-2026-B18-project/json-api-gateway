{
  "title": "Payment Service Monitoring",
  "uid": "payment-service-monitoring",
  "version": 1,
  "tags": ["payment-service", "spring-boot", "business"],
  "timezone": "browser",
  "schemaVersion": 39,
  "editable": true,
  "refresh": "10s",
  "panels": [
    {
      "title": "CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus_main" },
      "targets": [
        {
          "expr": "system_cpu_usage{service=\"json-payment-service\"}",
          "legendFormat": "CPU"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "palette-classic" },
          "custom": { "showPoints": "never" }
        }
      },
      "options": {
        "legend": {
          "calcs": ["mean", "max", "min"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "title": "Uptime",
      "type": "stat",
      "gridPos": { "h": 6, "w": 3, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus_main" },
      "targets": [
        {
          "expr": "process_uptime_seconds{service=\"json-payment-service\"}",
          "legendFormat": "Uptime"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null }
            ]
          }
        }
      }
    },
    {
      "title": "CPU Usage",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 3, "x": 3, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus_main" },
      "targets": [
        {
          "expr": "system_cpu_usage{service=\"json-payment-service\"}",
          "legendFormat": "CPU"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      }
    },
    {
      "title": "Heap Used",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 3, "x": 6, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus_main" },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{service=\"json-payment-service\", area=\"heap\"} / jvm_memory_max_bytes{service=\"json-payment-service\", area=\"heap\"} * 100",
          "legendFormat": "Heap"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "title": "Live Threads",
      "type": "stat",
      "gridPos": { "h": 6, "w": 3, "x": 9, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus_main" },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{service=\"json-payment-service\"}",
          "legendFormat": "Threads"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      }
    },
    {
      "title": "Open File Descriptors",
      "type": "stat",
      "gridPos": { "h": 6, "w": 3, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus_main" },
      "targets": [
        {
          "expr": "process_files_open_files{service=\"json-payment-service\"}",
          "legendFormat": "FDs"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 200 },
              { "color": "red", "value": 400 }
            ]
          }
        }
      }
    },
    {
      "title": "Disk Usage",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 3, "x": 15, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus_main" },
      "targets": [
        {
          "expr": "disk_free_bytes{service=\"json-payment-service\"} / disk_total_bytes{service=\"json-payment-service\"} * 100",
          "legendFormat": "Disk Free"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 80 },
              { "color": "red", "value": 95 }
            ]
          }
        }
      }
    },
    {
      "title": "409 Idempotency Collision Rate",
      "type": "stat",
      "gridPos": { "h": 6, "w": 3, "x": 18, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus_main" },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{service=\"json-payment-service\", status=\"409\"}[1m])",
          "legendFormat": "409/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.1 },
              { "color": "red", "value": 0.5 }
            ]
          }
        }
      }
    },
    {
      "title": "Active HikariCP Connections",
      "type": "stat",
      "gridPos": { "h": 6, "w": 3, "x": 21, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus_main" },
      "targets": [
        {
          "expr": "hikaricp_connections_active{service=\"json-payment-service\"}",
          "legendFormat": "Active"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 5 },
              { "color": "red", "value": 9 }
            ]
          }
        }
      }
    },

    {
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus_main" },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{service=\"json-payment-service\"}[1m])",
          "legendFormat": "{{method}} {{uri}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "showPoints": "never" }
        }
      }
    },
    {
      "title": "Error Rate (4xx+5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus_main" },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{service=\"json-payment-service\", status=~\"[45]..\"}[1m])",
          "legendFormat": "{{method}} {{uri}} {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "showPoints": "never" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.1 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "title": "Latency P95",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus_main" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_server_requests_seconds_bucket{service=\"json-payment-service\"}[5m]))",
          "legendFormat": "{{method}} {{uri}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": { "showPoints": "never" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.5 },
              { "color": "red", "value": 2 }
            ]
          }
        }
      }
    },

    {
      "title": "Heap Memory by Region",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus_main" },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{service=\"json-payment-service\", area=\"heap\"}",
          "legendFormat": "{{id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" },
          "custom": { "showPoints": "never" }
        }
      }
    },
    {
      "title": "Non-Heap Memory by Region",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus_main" },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{service=\"json-payment-service\", area=\"nonheap\"}",
          "legendFormat": "{{id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" },
          "custom": { "showPoints": "never" }
        }
      }
    },
    {
      "title": "HikariCP Connection Pool",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus_main" },
      "targets": [
        {
          "expr": "hikaricp_connections_active{service=\"json-payment-service\"}",
          "legendFormat": "Active"
        },
        {
          "expr": "hikaricp_connections_idle{service=\"json-payment-service\"}",
          "legendFormat": "Idle"
        },
        {
          "expr": "hikaricp_connections_pending{service=\"json-payment-service\"}",
          "legendFormat": "Pending"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "palette-classic" },
          "custom": { "showPoints": "never" }
        }
      }
    },

    {
      "title": "Transaction Error Rate by Endpoint (4xx+5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "prometheus_main" },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{service=\"json-payment-service\", status=~\"[45]..\"}[1m])",
          "legendFormat": "{{method}} {{uri}} {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "showPoints": "never" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.1 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "title": "422 Insufficient Balance Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "prometheus_main" },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{service=\"json-payment-service\", status=\"422\"}[1m])",
          "legendFormat": "{{uri}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "showPoints": "never" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.05 },
              { "color": "red", "value": 0.2 }
            ]
          }
        }
      }
    },
    {
      "title": "P95 Latency — Money Endpoints (POST)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "prometheus_main" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_server_requests_seconds_bucket{service=\"json-payment-service\", method=\"POST\", uri=~\"/topups|/withdrawals|/internal/wallets/deduct|/internal/wallets/refund|/internal/wallets/earnings\"}[5m]))",
          "legendFormat": "{{uri}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": { "showPoints": "never" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.5 },
              { "color": "red", "value": 2 }
            ]
          }
        }
      }
    },

    {
      "title": "Internal Endpoint Error Rate (4xx+5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 38 },
      "datasource": { "type": "prometheus", "uid": "prometheus_main" },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{service=\"json-payment-service\", uri=~\"/internal/.*\", status=~\"[45]..\"}[1m])",
          "legendFormat": "{{method}} {{uri}} {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "showPoints": "never" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.1 },
              { "color": "red", "value": 0.5 }
            ]
          }
        }
      }
    },
    {
      "title": "Internal Endpoint Latency P99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 38 },
      "datasource": { "type": "prometheus", "uid": "prometheus_main" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(http_server_requests_seconds_bucket{service=\"json-payment-service\", uri=~\"/internal/.*\"}[5m]))",
          "legendFormat": "{{uri}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": { "showPoints": "never" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    }
  ]
}
